<UserControl x:Class="OpenForestUI.MVVM.View.IngameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModel="clr-namespace:OpenForestUI.MVVM.ViewModel"
             xmlns:local="clr-namespace:OpenForestUI.MVVM.View"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="695" d:DesignWidth="1080">
    <UserControl.Resources>
        <Storyboard AccelerationRatio="0.4" DecelerationRatio="0.4" x:Key="Open">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.Width)">
                <SplineDoubleKeyFrame KeyTime="00:00:0.2" Value="1080"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.Opacity)">
                <SplineDoubleKeyFrame KeyTime="00:00:0.2" Value="1"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard AccelerationRatio="0.4" DecelerationRatio="0.4" x:Key="Close">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.Width)">
                <SplineDoubleKeyFrame KeyTime="00:00:0.2" Value="360"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(Border.Opacity)">
                <SplineDoubleKeyFrame KeyTime="00:00:0.2" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard AccelerationRatio="0.4" DecelerationRatio="0.4" x:Key="HideTeams">
            <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                <SplineThicknessKeyFrame KeyTime="00:00:0.5" Value="0,-400,0,0" />
            </ThicknessAnimationUsingKeyFrames>
        </Storyboard>
        <Storyboard AccelerationRatio="0.4" DecelerationRatio="0.4" x:Key="ShowTeams">
            <ThicknessAnimationUsingKeyFrames Storyboard.TargetProperty="Margin" BeginTime="00:00:00">
                <SplineThicknessKeyFrame KeyTime="00:00:0.5" Value="0,0,0,0" />
            </ThicknessAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Settings row: label left, Fluent toggle right. Each panel's DataContext is its tab
             view-model, so IsChecked binds straight to the *IsActive property (TwoWay = same persisted
             write the old click command did). -->
        <Style x:Key="IgRow" TargetType="Grid">
            <Setter Property="Height" Value="46"/>
        </Style>
        <Style x:Key="IgRowLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
        </Style>
        <Style x:Key="IgSep" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Border.Subtle}"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
        <Style x:Key="IgHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Border Width="1080" Height="695" x:Name="OpenContent">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsOpen}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard Storyboard="{StaticResource Open}"/>
                        </DataTrigger.EnterActions>
                        <DataTrigger.ExitActions>
                            <BeginStoryboard Storyboard="{StaticResource Close}"/>
                        </DataTrigger.ExitActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <StackPanel x:Name="MainContainer" Orientation="Vertical" ScrollViewer.ScrollChanged="MainContainer_ScrollChanged">
                <!-- Collapsible team-roster editor (unchanged), revealed by the chevron. -->
                <Border Height="430" Margin="0,-400,0,0" x:Name="TeamsContent">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TeamsIsOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource ShowTeams}"/>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard Storyboard="{StaticResource HideTeams}"/>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <ContentControl Content="{Binding IngameTeamsVM }" />
                        <Border Grid.Row="1" Width="100" Height="30" VerticalAlignment="Top" HorizontalAlignment="Center" Background="#2f2f36">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="{Binding TeamsButtonCommand.MouseGesture}" Command="{Binding TeamsButtonCommand}"/>
                            </Border.InputBindings>
                            <Image Width="100">
                                <Image.Source>
                                    <BitmapImage UriSource="/Assets/Images/ArrowsDownWhite.png"/>
                                </Image.Source>
                            </Image>
                        </Border>
                    </Grid>
                </Border>

                <!-- Feature toggles: three grouped cards (Objectives / Players / Teams). -->
                <StackPanel Orientation="Horizontal" Margin="0,-30,0,0">

                    <Border x:Name="ObjectivePanel" Width="360">
                        <ui:Card VerticalAlignment="Top" Margin="12,8,12,10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Objectives" Style="{StaticResource IgHeader}"/>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Baron PowerPlay" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding BaronIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Elder PowerPlay" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ElderIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Inhibitor Timers" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding InhibIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Objective Spawn Pop-up" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ObjectiveSpawnPopUpIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Objective Kill Pop-up" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ObjectiveKillPopUpIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Dragon Timer" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding DragonTimerIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}" IsEnabled="False" Opacity="0.5">
                                    <TextBlock Text="Baron Timer" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding BaronTimerIsActive, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                    </Border>

                    <Border x:Name="PlayerPanel" Width="360">
                        <ui:Card VerticalAlignment="Top" Margin="12,8,12,10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Players" Style="{StaticResource IgHeader}"/>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Item Notifications" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ItemsIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Level Up Notifications" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding LevelUpIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Gold Tab" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding PlayerGoldIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="CS per Min" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding PlayerCSPerMinIsActive, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                    </Border>

                    <Border x:Name="TeamPanel" Width="360">
                        <ui:Card VerticalAlignment="Top" Margin="12,8,12,10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Teams" Style="{StaticResource IgHeader}"/>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Scoreboard" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ScoreboardIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Team Names" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding NamesIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Team Scores" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding ScoresIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Team Icons" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding IconsIsActive, Mode=TwoWay}"/>
                                </Grid>
                                <Border Style="{StaticResource IgSep}"/>
                                <Grid Style="{StaticResource IgRow}">
                                    <TextBlock Text="Gold Graph" Style="{StaticResource IgRowLabel}"/>
                                    <ui:ToggleSwitch HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="{Binding GoldGraphIsActive, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>
                        </ui:Card>
                    </Border>

                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
