<Window x:Class="OpenForestUI.MVVM.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:OpenForestUI.MVVM.ViewModel"
        xmlns:services="clr-namespace:OpenForestUI.MVVM.Core.Services"
        xmlns:behaviors="clr-namespace:OpenForestUI.MVVM.Behaviors"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:OpenForestUI"
        mc:Ignorable="d"
        Title="OpenForestUI"
        Icon="../../Assets/Icons/OpenForestUI.ico"
        Height="756" Width="1280"
        MinHeight="756" MaxHeight="756" MinWidth="1280" MaxWidth="1280"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        d:DataContext="{d:DesignInstance viewModel:MainViewModel}">

    <Window.Resources>
        <!-- Riot-style caption buttons: borderless / flat, transparent, fill the title-bar height,
             subtle gray hover. No default WPF button chrome (custom template). -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Bg.NavHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Close button: same flat look but a RED hover highlight (Riot / Windows style). -->
        <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E23636"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- DataContext is assigned from the DI container in BroadcastController.PostInit.
         Dashboard shell: full-height left rail (Col0, both rows) + a top bar over the content
         column (Col1/Row0) carrying the connection chip and window controls + the content host
         (Col1/Row1). Window height is 756 = 56 (top bar) + 700 (content) so the fixed 1080x695
         PickBan/Ingame pages still fit without scrolling. -->

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============================ Sidebar (full height) ============================ -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="1"
                Background="{DynamicResource Brush.Bg.Sidebar}">
            <DockPanel LastChildFill="True">

                <!-- Brand: logo over wordmark (stacked). The Venus Rising wordmark is wide all-caps and
                     won't fit beside the logo in the 200px rail, so it sits below at a size that fits. -->
                <StackPanel DockPanel.Dock="Top" Margin="12,18,12,16" HorizontalAlignment="Center">
                    <Image Height="46" Width="46" HorizontalAlignment="Center"
                           Source="../../Assets/Images/OpenForestUI_icon.png"/>
                    <TextBlock Text="OpenForestUI" HorizontalAlignment="Center" Margin="0,8,0,0"
                               FontFamily="pack://application:,,,/Assets/Fonts/#Venus Rising"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="14" FontWeight="Normal"/>
                </StackPanel>

                <!-- Settings pinned to the bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,12">
                    <Border Height="1" Background="{DynamicResource Brush.Border.Subtle}" Margin="16,0,16,8"/>
                    <RadioButton AutomationProperties.Name="Settings"
                                 Style="{StaticResource MenuButtonTheme}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="{x:Static services:AppRoute.Settings}"
                                 IsChecked="{Binding Nav.CurrentRoute, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static services:AppRoute.Settings}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Primary navigation -->
                <StackPanel x:Name="Navigation" Margin="0,2,0,0">
                    <RadioButton AutomationProperties.Name="Home"
                                 Style="{StaticResource MenuButtonTheme}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="{x:Static services:AppRoute.Home}"
                                 IsChecked="{Binding Nav.CurrentRoute, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static services:AppRoute.Home}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Home24" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Home" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <TextBlock Text="OVERLAYS" Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.65" Margin="26,16,0,4"/>

                    <RadioButton AutomationProperties.Name="Pre Game"
                                 Style="{StaticResource MenuButtonTheme}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="{x:Static services:AppRoute.PickBan}"
                                 IsChecked="{Binding Nav.CurrentRoute, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static services:AppRoute.PickBan}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="People24" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Pre Game" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton AutomationProperties.Name="Ingame"
                                 Style="{StaticResource MenuButtonTheme}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="{x:Static services:AppRoute.Ingame}"
                                 IsChecked="{Binding Nav.CurrentRoute, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static services:AppRoute.Ingame}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Play24" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Ingame" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton AutomationProperties.Name="Post Game"
                                 Style="{StaticResource MenuButtonTheme}"
                                 Command="{Binding NavigateCommand}"
                                 CommandParameter="{x:Static services:AppRoute.PostGame}"
                                 IsChecked="{Binding Nav.CurrentRoute, Converter={StaticResource EnumToBool}, ConverterParameter={x:Static services:AppRoute.PostGame}, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Trophy24" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Post Game" FontSize="15" Margin="14,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================ Top bar (over content) ============================ -->
        <Border Grid.Column="1" Grid.Row="0" Panel.ZIndex="1"
                Background="{DynamicResource Brush.Bg.Content}"
                BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" behaviors:WindowDragBehavior.EnableDrag="True">

                <!-- Window controls (right edge, full height) -->
                <Button x:Name="ExitApp" DockPanel.Dock="Right"
                        Style="{StaticResource CloseCaptionButton}" ToolTip="Close"
                        Command="{Binding CloseCommand}">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="15" Foreground="{DynamicResource Brush.Text.Primary}"/>
                </Button>
                <Button x:Name="MinimizeApp" DockPanel.Dock="Right"
                        Style="{StaticResource CaptionButton}" ToolTip="Minimize"
                        Command="{Binding MinimizeCommand}">
                    <ui:SymbolIcon Symbol="Subtract24" FontSize="15" Foreground="{DynamicResource Brush.Text.Primary}"/>
                </Button>

                <!-- Connection status chip: colored state dot with a radar-ping pulse + label -->
                <Border x:Name="ConnectionStatus" DockPanel.Dock="Right" VerticalAlignment="Center"
                        Margin="0,0,16,0" Padding="12,6" CornerRadius="14"
                        Background="{DynamicResource Brush.Surface.Card}"
                        BorderBrush="{DynamicResource Brush.Border.Subtle}" BorderThickness="1"
                        DataContext="{Binding Path=State.ConnectionStatus}">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,9,0">
                            <Ellipse x:Name="StatusHalo" Width="9" Height="9"
                                     Fill="{Binding Path=BorderColor}" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="9" Height="9" Fill="{Binding Path=BorderColor}"/>
                        </Grid>
                        <TextBlock Text="{Binding Path=TextContent}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="12" FontWeight="Medium"/>
                    </StackPanel>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="StatusHalo"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                        From="1" To="2.6" Duration="0:0:1.8"/>
                                    <DoubleAnimation Storyboard.TargetName="StatusHalo"
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                        From="1" To="2.6" Duration="0:0:1.8"/>
                                    <DoubleAnimation Storyboard.TargetName="StatusHalo"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0.7" To="0" Duration="0:0:1.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Remaining space is the draggable region -->
                <Border Background="Transparent"/>
            </DockPanel>
        </Border>

        <!-- ============================ Content host ============================ -->
        <Grid Grid.Column="1" Grid.Row="1" Background="{DynamicResource Brush.Bg.Content}">
            <!-- Stretch (no V/H alignment) so pages fill the content area exactly as before;
                 their own internal alignment handles centering. -->
            <ContentControl Content="{Binding Nav.CurrentView}" Width="1080"/>
        </Grid>
    </Grid>
</Window>
