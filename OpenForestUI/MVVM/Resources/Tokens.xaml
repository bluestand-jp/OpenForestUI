<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Design tokens — the single source of truth for the menu's colors and key dimensions.
        Values are lifted from the literals previously scattered inline across MainWindow.xaml and
        the theme dictionaries. This dictionary is merged FIRST in App.xaml so themes and views can
        reference these tokens; the migration re-points the hard-coded literals onto these keys
        incrementally (themes first, then the shell, then the new Home view).
    -->

    <!-- ============================ Colors ============================ -->
    <Color x:Key="Color.Bg.Titlebar">#16161A</Color>
    <Color x:Key="Color.Bg.Sidebar">#2F2F36</Color>
    <Color x:Key="Color.Bg.Content">#212126</Color>
    <Color x:Key="Color.Bg.NavHover">#40404A</Color>
    <Color x:Key="Color.Surface.Card">#2F2F36</Color>

    <Color x:Key="Color.Accent">#5CC59E</Color>
    <Color x:Key="Color.Accent.Blue">#4C91C8</Color>
    <Color x:Key="Color.Accent.BlueDeep">#0063B1</Color>

    <Color x:Key="Color.Border">#617398</Color>
    <Color x:Key="Color.Border.Subtle">#333333</Color>

    <Color x:Key="Color.Text.Primary">#FFFFFF</Color>
    <Color x:Key="Color.Text.Secondary">#CCCCCC</Color>

    <!-- ============================ Brushes ============================ -->
    <SolidColorBrush x:Key="Brush.Bg.Titlebar" Color="{StaticResource Color.Bg.Titlebar}" />
    <SolidColorBrush x:Key="Brush.Bg.Sidebar" Color="{StaticResource Color.Bg.Sidebar}" />
    <SolidColorBrush x:Key="Brush.Bg.Content" Color="{StaticResource Color.Bg.Content}" />
    <SolidColorBrush x:Key="Brush.Bg.NavHover" Color="{StaticResource Color.Bg.NavHover}" />
    <SolidColorBrush x:Key="Brush.Surface.Card" Color="{StaticResource Color.Surface.Card}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Accent.Blue" Color="{StaticResource Color.Accent.Blue}" />
    <SolidColorBrush x:Key="Brush.Accent.BlueDeep" Color="{StaticResource Color.Accent.BlueDeep}" />

    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.Border.Subtle" Color="{StaticResource Color.Border.Subtle}" />

    <SolidColorBrush x:Key="Brush.Text.Primary" Color="{StaticResource Color.Text.Primary}" />
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Color.Text.Secondary}" />

    <!-- ============================ Dimensions ============================ -->
    <sys:Double x:Key="Dim.Shell.Width">1280</sys:Double>
    <sys:Double x:Key="Dim.Shell.Height">756</sys:Double>
    <sys:Double x:Key="Dim.Titlebar.Height">56</sys:Double>
    <sys:Double x:Key="Dim.Sidebar.Width">200</sys:Double>
    <sys:Double x:Key="Dim.Content.Width">1080</sys:Double>

</ResourceDictionary>
