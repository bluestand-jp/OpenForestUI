<UserControl x:Class="OpenForestUI.MVVM.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="695" d:DesignWidth="1080">

    <!-- Landing dashboard. The old InfoEdit slide-down overlay and its top chevron were removed from
         the Home flow per request; the InfoEditView / InfoEditViewModel feature code is kept (still in
         the project + DI) so it can be re-surfaced later. -->
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="OpenForestUI"
                       FontFamily="pack://application:,,,/Assets/Fonts/#Venus Rising"
                       Foreground="{DynamicResource Brush.Text.Primary}"
                       FontSize="42" FontWeight="Normal" HorizontalAlignment="Center"/>
            <TextBlock Text="Broadcast Overlays"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       FontSize="18" FontWeight="Light" HorizontalAlignment="Center" Margin="0,4,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,40,0,0">
                <!-- Pick Ban -->
                <ui:Card Width="270" Height="300" Margin="16" DataContext="{Binding PickBanVM}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="Enable" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="13"/>
                            <ui:ToggleSwitch IsChecked="{Binding IsActive, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Pre Game" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Text.Primary}" FontSize="28" FontWeight="Light"/>
                            <TextBlock Text="Champion select overlay" HorizontalAlignment="Center" Margin="0,6,0,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="13"/>
                        </StackPanel>
                        <ui:Button Grid.Row="2" Content="Open" Appearance="Primary"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                   Command="{Binding OpenCommand}"/>
                    </Grid>
                </ui:Card>

                <!-- Ingame -->
                <ui:Card Width="270" Height="300" Margin="16" DataContext="{Binding IngameVM}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="Enable" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="13"/>
                            <ui:ToggleSwitch IsChecked="{Binding IsActive, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Ingame" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Text.Primary}" FontSize="28" FontWeight="Light"/>
                            <TextBlock Text="Live scoreboard overlay" HorizontalAlignment="Center" Margin="0,6,0,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="13"/>
                        </StackPanel>
                        <ui:Button Grid.Row="2" Content="Open" Appearance="Primary"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                   Command="{Binding OpenCommand}"/>
                    </Grid>
                </ui:Card>

                <!-- Post Game -->
                <ui:Card Width="270" Height="300" Margin="16" DataContext="{Binding PostGameVM}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Enable toggle grayed out per request (PostGame unused) -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    IsEnabled="False" Opacity="0.5">
                            <TextBlock Text="Enable" VerticalAlignment="Center" Margin="0,0,8,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="13"/>
                            <ui:ToggleSwitch IsChecked="{Binding IsActive, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Post Game" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Text.Primary}" FontSize="28" FontWeight="Light"/>
                            <TextBlock Text="Match results overlay" HorizontalAlignment="Center" Margin="0,6,0,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}" FontSize="13"/>
                        </StackPanel>
                        <!-- Open grayed out per request (PostGame unused) — matches the disabled Enable toggle above -->
                        <ui:Button Grid.Row="2" Content="Open" Appearance="Primary"
                                   IsEnabled="False" Opacity="0.5"
                                   HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                   Command="{Binding OpenCommand}"/>
                    </Grid>
                </ui:Card>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
