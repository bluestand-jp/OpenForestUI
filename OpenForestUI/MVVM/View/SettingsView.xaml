<UserControl x:Class="OpenForestUI.MVVM.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="695" d:DesignWidth="1080">

    <!-- Fluent settings page (WPF-UI). The view-model (OffsetUpdate / UseMemoryReader / UseMock)
         and the two ComboBox SelectionChanged handlers in code-behind are unchanged; only the
         controls are swapped to their Fluent equivalents and grouped into ui:Card rows. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="48,32,48,32">
        <StackPanel MaxWidth="660" HorizontalAlignment="Left">

            <TextBlock Text="Settings"
                       Foreground="{DynamicResource Brush.Text.Primary}"
                       FontSize="34" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <TextBlock Text="Application and overlay preferences"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       FontSize="14" Margin="0,0,0,22"/>

            <!-- Auto update offsets (grayed out / disabled — feature not used) -->
            <ui:Card Margin="0,0,0,10" Padding="18,14" IsEnabled="False" Opacity="0.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Text="Auto update offsets"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="15" FontWeight="Medium"/>
                    <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                     IsChecked="{Binding OffsetUpdate, Mode=TwoWay}"/>
                </Grid>
            </ui:Card>

            <!-- Use Memory Reader (Farsight) (grayed out / disabled — feature not used) -->
            <ui:Card Margin="0,0,0,10" Padding="18,14" IsEnabled="False" Opacity="0.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Use Memory Reader (Farsight)"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="15" FontWeight="Medium"/>
                        <TextBlock Text="Disabled by default — required for Vanguard environments. Enable only on systems where ReadProcessMemory works."
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                     IsChecked="{Binding UseMemoryReader, Mode=TwoWay}"/>
                </Grid>
            </ui:Card>

            <!-- Use Mock (preview overlay) -->
            <ui:Card Margin="0,0,0,10" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Use Mock (preview overlay)"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="15" FontWeight="Medium"/>
                        <TextBlock Text="Feed a canned game state to the Ingame overlay so the broadcast top bar can be previewed/tuned in OBS without a live game. Turn off before a real game."
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                     AutomationProperties.Name="Use Mock"
                                     IsChecked="{Binding UseMock, Mode=TwoWay}"/>
                </Grid>
            </ui:Card>

            <!-- OCR (accurate CS/Gold): provision the bundled-Python environment on demand. -->
            <ui:Card Margin="0,0,0,10" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="OCR (accurate CS / Gold)"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="15" FontWeight="Medium"/>
                        <TextBlock Text="{Binding OcrStatusText}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ui:Button Grid.Column="1" VerticalAlignment="Center"
                               Content="Set up OCR now"
                               AutomationProperties.Name="Set up OCR"
                               Click="OcrSetup_Click"/>
                </Grid>
            </ui:Card>

            <!-- Log level -->
            <ui:Card Margin="0,0,0,10" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Text="Log level"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="15" FontWeight="Medium"/>
                    <ComboBox Grid.Column="1" x:Name="LogLevelSelector" Width="200"
                              SelectionChanged="LogLevelSelector_SelectionChanged">
                        <ComboBoxItem Tag="None" Content="None"/>
                        <ComboBoxItem Tag="Warn" Content="Warn"/>
                        <ComboBoxItem Tag="Info" Content="Info"/>
                        <ComboBoxItem Tag="Verbose" Content="Verbose"/>
                    </ComboBox>
                </Grid>
            </ui:Card>

            <!-- Overlay language -->
            <ui:Card Margin="0,0,0,10" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="Overlay language"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="15" FontWeight="Medium"/>
                        <TextBlock Text="Requires restart to apply."
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" x:Name="LangSelector" Width="200"
                              SelectedValuePath="Tag"
                              SelectionChanged="LangSelector_SelectionChanged">
                        <ComboBoxItem Tag="en_US" Content="English"/>
                        <ComboBoxItem Tag="de_DE" Content="Deutsch"/>
                        <ComboBoxItem Tag="pt_BR" Content="Português"/>
                        <ComboBoxItem Tag="fr_FR" Content="Français"/>
                        <ComboBoxItem Tag="es_ES" Content="Español"/>
                        <ComboBoxItem Tag="it_IT" Content="Italiano"/>
                        <ComboBoxItem Tag="ja_JP" Content="日本語"/>
                        <ComboBoxItem Tag="tr_TR" Content="Türkçe"/>
                        <ComboBoxItem Tag="hu_HU" Content="Magyar"/>
                        <ComboBoxItem Tag="pl_PL" Content="Polski"/>
                        <ComboBoxItem Tag="ru_RU" Content="Русский"/>
                        <ComboBoxItem Tag="ro_RO" Content="Română"/>
                        <ComboBoxItem Tag="cs_CZ" Content="Čeština"/>
                        <ComboBoxItem Tag="zh_CN" Content="简体字"/>
                        <ComboBoxItem Tag="zh-TW" Content="繁体字"/>
                        <ComboBoxItem Tag="ko_KR" Content="한국말"/>
                    </ComboBox>
                </Grid>
            </ui:Card>

            <!-- Footer: credits + version (placeholder text; edit in SettingsViewModel.Credits) -->
            <Border Height="1" Background="{DynamicResource Brush.Border.Subtle}" Margin="0,26,0,14"/>
            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="{Binding AppVersion}" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Brush.Text.Primary}"
                           FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Credits}" HorizontalAlignment="Center" Margin="0,4,0,0"
                           Foreground="{DynamicResource Brush.Text.Secondary}"
                           FontSize="11"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
